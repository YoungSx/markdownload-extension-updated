{
  "packageManager": "npm@11.8.0",
  "scripts": {
    "npminstall": "npm install",
    "generate:release-highlights": "node scripts/generate-release-highlights.js",
    "build:browser-manifests": "node scripts/generate-browser-manifests.js",
    "build:manifests": "npm run generate:release-highlights && npm run build:browser-manifests",
    "build": "npm run build:manifests && web-ext build -s .build/firefox",
    "build:chrome": "npm run build:manifests && cd .build/chrome && zip -r ../../../dist/marksnip-chrome-$(node -p \"require('../../manifest.json').version\").zip . -x '*.DS_Store'",
    "build:all": "npm run build && npm run build:chrome",
    "benchmark:popup": "node scripts/benchmark-popup-startup.js",
    "capture:store-gallery": "node scripts/capture-store-gallery.js",
    "capture:promo-marquee": "node scripts/capture-marquee-promo.js",
    "capture:promo-small": "node scripts/capture-small-promo-tile.js",
    "start:firefoxdeveloper": "web-ext run -f firefoxdeveloperedition -u https://en.wikipedia.org/wiki/Special:Random --bc",
    "start:chromedevwin": "web-ext run -t chromium --chromium-binary \"C:\\Program Files\\Google\\Chrome Dev\\Application\\chrome.exe\" -u https://en.wikipedia.org/wiki/Special:Random --bc",
    "start:waveboxwin": "web-ext run -t chromium --chromium-binary %localappdata%/WaveboxApp/Application/wavebox.exe",
    "start:androidwin11": "adb connect 127.0.0.1:58526 && web-ext run -t firefox-android --adb-device 127.0.0.1:58526 --firefox-apk org.mozilla.fenix",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test tests/e2e/extension.spec.js tests/e2e/notifications.spec.js tests/e2e/batch-processing.spec.js tests/e2e/command-download-regression.spec.js tests/e2e/click-clip.spec.js",
    "test:e2e:mathml": "playwright test tests/e2e/extension.spec.js -g \"clips native MathML\"",
    "test:firefox:focused": "jest --runTestsByPath tests/unit/firefox-build-config.test.js tests/unit/mathml-to-tex.test.js tests/integration/html-to-markdown-real.test.js",
    "test:firefox:live": "npm run build:browser-manifests && node scripts/run-firefox-live-smoke.js",
    "snapshot:live-markdown": "node scripts/capture-live-markdown-snapshots.js",
    "verify:live-snapshots": "npm run snapshot:live-markdown",
    "verify:live-snapshots:hidden": "npm run snapshot:live-markdown -- --include-hidden-content",
    "verify:firefox": "npm run test:firefox:focused && npm run test:firefox:live -- --headless && web-ext lint -s .build/firefox",
    "lint:js": "eslint .",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/jest": "^29.5.11",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "web-ext": "^7.4.0"
  }
}
